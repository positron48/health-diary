# Runtime
APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_URL=http://localhost:18080
APP_TIMEZONE=Europe/Moscow
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://health_diary:health_diary@postgres:5432/health_diary?sslmode=disable

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MODE=long_polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_SOCKS5_PROXY_ADDR=

# Web auth
AUTH_CODE_TTL=5m
AUTH_MAX_ATTEMPTS=5
SESSION_TTL=720h
SESSION_COOKIE_NAME=health_diary_session
SESSION_SECRET=

# Encryption of sensitive application columns
DATA_ENCRYPTION_KEY=
DATA_ENCRYPTION_KEY_VERSION=1
# 0 disables automatic raw-entry retention cleanup. Explicit user deletion still applies.
RAW_ENTRY_RETENTION_DAYS=0

# LLM: OpenAI-compatible provider
LLM_ENABLED=true
LLM_BASE_URL=https://api.polza.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini-2024-07-18
LLM_TIMEOUT=30s
LLM_SOCKS5_PROXY=
LLM_STORE_RAW_RESPONSE=false

# Worker
JOB_POLL_INTERVAL=1s
JOB_MAX_ATTEMPTS=5

# Observability
METRICS_ENABLED=true
METRICS_ADDR=:9090
